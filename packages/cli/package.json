{
  "name": "@cwr/cli",
  "version": "0.1.0",
  "description": "Terminal access to the Zama Confidential Token Wrappers Registry: list, show, wrap, unwrap, balance, faucet, snippet.",
  "license": "BSD-3-Clause-Clear",
  "type": "module",
  "bin": {
    "registry-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
