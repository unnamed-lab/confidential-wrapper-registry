    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@cwr/registry-sdk": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
