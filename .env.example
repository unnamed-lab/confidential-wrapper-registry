# --- RPC (server-side: CLI, contracts) ---
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# --- RPC (browser / Next.js public) ---
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# --- Wallet (optional; falls back to a dev placeholder + EIP-6963 discovery) ---
NEXT_PUBLIC_WALLETCONNECT_ID=

# --- Write commands / deploy (Sepolia only; NEVER commit a real key) ---
# Used by registry-cli faucet/wrap/unwrap/balance and Foundry deploys.
PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=

# --- Optional ---
ETHERSCAN_API_KEY=
